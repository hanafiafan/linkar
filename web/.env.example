PUBLIC_WEB3FORMS_KEY=
# URL produksi, contoh: https://linkar-xxx.vercel.app
PUBLIC_SITE_URL=

# Password login untuk Custom CMS Dashboard
ADMIN_PASSWORD=admin123


# Publish CMS ke GitHub (opsional — untuk update situs live di Vercel).
# Kalau diisi, tombol "Terbitkan" juga meng-commit seed.json ke repo
# sehingga Vercel membangun ulang situs statis secara otomatis.
GITHUB_TOKEN=
GITHUB_REPO=hanafiafan/LINKAR
GITHUB_BRANCH=main
GITHUB_CONTENT_PATH=web/src/content/seed.json

# Di Vercel, filesystem read-only — Simpan Draf & Buang Draf juga butuh
# GITHUB_TOKEN di atas supaya draft.json bisa dikommit (bukan cuma publish).
GITHUB_DRAFT_PATH=web/src/content/draft.json
