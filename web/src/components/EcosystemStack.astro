---
import type { SiteContent } from '../lib/content';

interface Props { content: SiteContent }
const { content } = Astro.props;
const cards = content.entities.filter((e) => e.hasProfile && e.slug);
const FALLBACK_IMAGE = '/images/portfolio/aktivasi-01.jpg';
---
<div class="stack" data-card-stack tabindex="0" aria-roledescription="carousel" aria-label="Entitas ekosistem LINKAR">
  <div class="stack__cards">
    {cards.map((entity) => (
      <a href={`/brand/${entity.slug}`} class="stack-card">
        <img src={entity.heroImage || FALLBACK_IMAGE} alt="" loading="lazy" />
        <span class="stack-card__scrim"></span>
        <span class="stack-card__logo"><img src={entity.logo} alt={`Logo ${entity.name}`} loading="lazy" /></span>
        <span class="stack-card__body">
          <b>{entity.name}</b>
          <span class="stack-card__role">{entity.role} · {entity.tagline}</span>
          <span class="stack-card__cta">Lihat profil →</span>
        </span>
      </a>
    ))}
  </div>

  <div class="stack-dots" role="tablist" aria-label="Pilih entitas">
    {cards.map((entity, i) => (
      <button type="button" aria-label={entity.name} aria-current={i === 0 ? 'true' : 'false'} class:list={{ 'is-active': i === 0 }}></button>
    ))}
  </div>
</div>

<style>
  .stack{ margin-top:64px; outline:none; }
  .stack__cards{
    position:relative;
    height:340px;
    display:flex;
    align-items:center;
    justify-content:center;
  }

  .stack-card{
    position:absolute;
    width:480px; height:300px;
    border-radius:24px;
    overflow:hidden;
    display:flex; flex-direction:column; justify-content:flex-end;
    padding:24px;
    will-change:transform, opacity;
    box-shadow:0 20px 50px rgba(0,0,0,.35);
  }
  .stack-card img{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:-2; }
  .stack-card__scrim{
    position:absolute; inset:0; z-index:-1;
    background:linear-gradient(180deg, rgba(10,17,40,.15) 0%, rgba(10,17,40,.85) 100%);
  }
  .stack-card__logo{
    position:absolute; top:20px; left:20px;
    background:#fff; border-radius:10px; padding:8px 12px;
    display:inline-flex; align-items:center;
  }
  .stack-card__logo img{ position:static; height:22px; width:auto; max-width:80px; object-fit:contain; z-index:auto; }
  .stack-card__body{ display:flex; flex-direction:column; gap:6px; color:#fff; }
  .stack-card__body b{ font-size:1.3rem; }
  .stack-card__role{ font-size:.85rem; color:var(--muted); }
  .stack-card__cta{
    font-weight:700; color:var(--orange); font-size:.85rem;
    opacity:0; transform:translateY(6px); transition:opacity .25s, transform .25s;
  }
  .stack-card.is-active .stack-card__cta{ opacity:1; transform:translateY(0); }
  .stack-card:not(.is-active){ cursor:pointer; }

  .stack-dots{ display:flex; justify-content:center; gap:10px; margin-top:28px; }
  .stack-dots button{
    width:10px; height:10px; border-radius:50%; border:0; padding:0;
    background:rgba(255,255,255,.25); cursor:pointer; transition:background .2s, transform .2s;
  }
  .stack-dots button.is-active{ background:var(--orange); transform:scale(1.2); }

  @media (max-width:700px){
    .stack__cards{ height:240px; }
    .stack-card{ width:300px; height:200px; padding:16px; border-radius:18px; }
    .stack-card__body b{ font-size:1.05rem; }
  }
</style>

<script>
  import initCardStack from '../scripts/card-stack.js';

  document.querySelectorAll<HTMLElement>('[data-card-stack]').forEach((root) => initCardStack(root));
</script>
