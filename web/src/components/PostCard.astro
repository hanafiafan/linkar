---
import type { PostDoc } from '../lib/content';

interface Props { post: PostDoc }
const { post } = Astro.props;
const dateLabel = new Intl.DateTimeFormat('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(post.date));
---
<a href={`/blog/${post.slug}`} class="card">
  <span class="cover">
    <img src={post.cover} alt={post.title} loading="lazy" />
    <span class="duo" aria-hidden="true"></span>
  </span>
  <span class="body">
    <time class="date" datetime={post.date}>{dateLabel}</time>
    <h3>{post.title}</h3>
    <p class="excerpt">{post.excerpt}</p>
  </span>
</a>

<style>
  .card{display:block;border-radius:var(--radius-s);overflow:hidden;background:var(--navy-panel)}
  .cover{display:block;position:relative;aspect-ratio:16/10;overflow:hidden}
  .cover img{width:100%;height:100%;object-fit:cover;filter:grayscale(1) contrast(1.05) brightness(.95);transition:filter .4s,transform .4s}
  .duo{position:absolute;inset:0;background:var(--navy-logo);mix-blend-mode:color;transition:opacity .4s}
  .card:hover .cover img,.card:focus-visible .cover img{filter:none;transform:scale(1.03)}
  .card:hover .duo,.card:focus-visible .duo{opacity:0}
  .body{display:block;padding:20px}
  .date{display:block;color:var(--muted);font-size:.82rem;margin-bottom:8px}
  h3{font-size:1.15rem}
  .excerpt{color:var(--muted);font-size:.92rem;margin-top:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  @media (prefers-reduced-motion: reduce){.cover img,.duo{transition:none}}
</style>
