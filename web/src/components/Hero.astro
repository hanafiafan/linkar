---
import type { SiteContent } from '../lib/content';

interface Props { content: SiteContent }
const { content } = Astro.props;
const { hero } = content.home;

const highlightIdx = hero.title.toLowerCase().indexOf(hero.highlight.toLowerCase());
let titleBefore = hero.title;
let titleHighlight = '';
let titleAfter = '';
if (highlightIdx !== -1) {
  titleBefore = hero.title.slice(0, highlightIdx);
  titleHighlight = hero.title.slice(highlightIdx, highlightIdx + hero.highlight.length);
  titleAfter = hero.title.slice(highlightIdx + hero.highlight.length);
}
---
<section class="hero">
  <div class="wrap hero__inner">
    <div class="hero__content">
      <span class="kicker" data-reveal="pop">{hero.badge}</span>

      <h1 class="hero__title" data-split>{titleBefore}<span class="accent">{titleHighlight}</span>{titleAfter}</h1>

      <div class="hero__sub" data-reveal>
        <p class="hero__sub-en">{hero.subEn}</p>
        <p class="hero__sub-id">{hero.subId}</p>
      </div>

      <div class="hero__actions" data-reveal>
        <a href="#contact" class="btn btn-primary">{hero.primaryCta}</a>
        <a href="#portfolio" class="btn btn-ghost">{hero.secondaryCta}</a>
      </div>

      <div class="hero__stats" data-stagger>
        {hero.miniStats.map((stat) => (
          <div class="hero__stat">
            <span class="hero__stat-value">{stat.value}</span>
            <span class="hero__stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="hero-photo" data-morph>
      <img data-hero-photo src="/images/portfolio/aktivasi-01.jpg" alt="Peserta program Artha Affiliate Kickstart berkumpul usai sesi" />
      <canvas class="hero3d-canvas" hidden></canvas>
      <span class="hero3d-caption" hidden>LINKAR</span>
    </div>
  </div>
</section>

<style>
  .hero{
    position:relative;
    min-height:92vh;
    display:flex;
    align-items:center;
    background:var(--navy);
    overflow:hidden;
  }
  .hero::before{
    content:'';
    position:absolute; inset:0;
    background:radial-gradient(60% 50% at 80% 10%, rgba(242,106,33,.15), transparent);
    pointer-events:none;
  }

  .hero__inner{
    position:relative;
    z-index:1;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:64px;
    padding-top:64px;
    padding-bottom:64px;
  }

  .hero__content{
    display:flex;
    flex-direction:column;
    align-items:flex-start;
    gap:28px;
    flex:1;
  }

  .hero__title{
    font-size:clamp(2.4rem, 6vw, 4.6rem);
    max-width:900px;
    color:var(--text);
  }
  .hero__title .accent{ color:var(--orange); }

  .hero__sub{ max-width:620px; display:flex; flex-direction:column; gap:10px; }
  .hero__sub-en{ font-style:italic; font-weight:600; color:var(--orange); font-size:1.15rem; }
  .hero__sub-id{ color:var(--muted); font-size:1rem; }

  .hero__actions{ display:flex; align-items:center; gap:18px; flex-wrap:wrap; }

  .hero__stats{ display:flex; align-items:center; gap:40px; margin-top:8px; flex-wrap:wrap; }
  .hero__stat{ display:flex; flex-direction:column; gap:4px; }
  .hero__stat-value{ font-size:2rem; font-weight:800; color:var(--text); line-height:1; }
  .hero__stat-label{ font-size:.85rem; color:var(--muted); }

  .hero-photo{
    display:none;
    flex-shrink:0;
    width:380px;
    aspect-ratio:4/5;
    border-radius:var(--radius);
    background:var(--navy-panel);
    overflow:hidden;
  }
  .hero-photo img{ width:100%; height:100%; object-fit:cover; }
  .hero-photo img[src=""]{ display:none; }

  .hero-photo{ position:relative; }
  .hero-photo img{ transition:opacity .5s ease; }
  .hero-photo.is-3d-active img{ opacity:0; }
  .hero3d-canvas{
    position:absolute; inset:0; width:100%; height:100%;
    opacity:0; transition:opacity .5s ease;
  }
  .hero3d-canvas.is-active{ opacity:1; }

  .hero3d-caption{
    position:absolute; left:20px; bottom:18px;
    font-family:'Plus Jakarta Sans', sans-serif; font-weight:800; letter-spacing:.06em;
    color:#fff; font-size:1.1rem; opacity:0; transition:opacity .5s ease; pointer-events:none;
  }
  .hero3d-caption.is-active{ opacity:1; }

  @media (min-width: 1000px){
    .hero-photo{ display:block; }
  }
</style>

<script>
  // Lazy-load the interactive 3D hero logo: only on desktop, once the panel is
  // in view and the page has settled (load/idle). Falls back silently to the
  // static photo on any error or unsupported environment.
  const panel = document.querySelector<HTMLElement>('.hero-photo');
  const canvas = panel?.querySelector<HTMLCanvasElement>('.hero3d-canvas');
  const caption = panel?.querySelector<HTMLElement>('.hero3d-caption');

  if (panel && canvas && caption && matchMedia('(min-width: 1000px)').matches) {
    let triggered = false;

    const activate = () => {
      if (triggered) return;
      triggered = true;
      io.disconnect();

      const start = () =>
        import('../scripts/hero3d.js')
          .then(({ default: initHero3D }) => initHero3D(panel, canvas))
          .then(() => {
            canvas.hidden = false;
            caption.hidden = false;
            requestAnimationFrame(() => {
              panel.classList.add('is-3d-active');
              canvas.classList.add('is-active');
              caption.classList.add('is-active');
            });
          })
          .catch((err) => {
            console.warn('hero3d: falling back to static photo', err);
          });

      if ('requestIdleCallback' in window) {
        (window as any).requestIdleCallback(start, { timeout: 2000 });
      } else {
        setTimeout(start, 200);
      }
    };

    const io = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          if (document.readyState === 'complete') activate();
          else window.addEventListener('load', activate, { once: true });
        }
      },
      { threshold: 0.1 }
    );
    io.observe(panel);
  }
</script>
