---
import { buildNavLinks, buildBrandMenu } from '../lib/nav';
import type { SiteContent } from '../lib/content';

interface Props { content: SiteContent }
const { content } = Astro.props;
const links = buildNavLinks(content.programs.length, content.posts.length);
const brandMenu = buildBrandMenu(content.entities);
---
<header class="navbar" id="navbar">
  <div class="wrap navbar__inner">
    <a href="/" class="navbar__brand">
      <img src={content.settings.logoColor || '/images/brand/linkar-logo.png'} alt="LINKAR" class="navbar__logo" />
    </a>

    <input type="checkbox" id="navToggle" class="navbar__toggle" aria-hidden="true" />
    <label for="navToggle" class="navbar__burger" aria-label="Buka menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="navbar__nav" aria-label="Navigasi utama">
      <ul class="navbar__links">
        {links.map((link) => (
          link.href === '/#ecosystem' ? (
            <li>
              {brandMenu.length > 0 ? (
                <>
                  <button type="button" aria-expanded="false" aria-controls="mega" class="navbar__mega-trigger">{link.label}</button>
                  {brandMenu.length > 0 && (
                    <ul class="navbar__mega-mobile">
                      {brandMenu.map((b) => (
                        <li><a href={b.href}>{b.name}</a></li>
                      ))}
                      <li><a href="/#ecosystem">Lihat semua di beranda →</a></li>
                    </ul>
                  )}
                </>
              ) : (
                <a href={link.href}>{link.label}</a>
              )}
            </li>
          ) : (
            <li><a href={link.href}>{link.label}</a></li>
          )
        ))}
      </ul>
      <a href="/#contact" class="btn btn-primary navbar__cta">{content.settings.ctaLabel}</a>
    </nav>
  </div>

  {brandMenu.length > 0 && (
    <div id="mega" class="mega" hidden>
      <div class="wrap mega__inner">
        <div class="mega__grid">
          {brandMenu.map((b) => (
            <a href={b.href} class="mega__card">
              <span class="mega__logo"><img src={b.logo} alt={`Logo ${b.name}`} loading="lazy" /></span>
              <span class="mega__name">{b.name}</span>
              <span class="mega__role">{b.role}</span>
            </a>
          ))}
        </div>
        <a href="/#ecosystem" class="mega__all">Lihat semua di beranda →</a>
      </div>
    </div>
  )}
</header>

<style>
  .navbar{
    position:sticky; top:0; z-index:60;
    background:rgba(10,17,40,.85);
    backdrop-filter:blur(10px);
    -webkit-backdrop-filter:blur(10px);
    border-bottom:1px solid rgba(255,255,255,.08);
    transition:padding .3s;
  }
  .navbar__inner{
    display:flex; align-items:center; justify-content:space-between;
    gap:24px; padding:20px 24px;
  }
  .navbar.is-scrolled .navbar__inner{ padding:12px 24px; }

  .navbar__brand{
    display:inline-flex; align-items:center; gap:10px; flex-shrink:0;
    background:#fff; border-radius:12px; padding:6px 12px;
  }
  .navbar__logo{ height:48px; width:auto; display:block; transition:height .3s; }
  .navbar.is-scrolled .navbar__logo{ height:40px; }

  @media (max-width: 900px){
    .navbar__logo{ height:40px; }
  }

  .navbar__nav{ display:flex; align-items:center; gap:32px; }
  .navbar__links{ display:flex; align-items:center; gap:28px; list-style:none; }
  .navbar__links a{ font-weight:600; font-size:.95rem; color:var(--muted); transition:color .2s; }
  .navbar__links a:hover{ color:var(--text); }
  .navbar__cta{ padding:11px 22px; font-size:.9rem; white-space:nowrap; }

  .navbar__mega-trigger{
    font:inherit; font-weight:600; font-size:.95rem; color:var(--muted);
    background:none; border:0; padding:0; cursor:pointer; transition:color .2s;
  }
  .navbar__mega-trigger:hover, .navbar__mega-trigger[aria-expanded="true"]{ color:var(--text); }
  .navbar__mega-mobile{ display:none; }

  @media (max-width: 899px){
    .navbar__mega-trigger{ display:none; }
  }

  .mega{
    position:absolute; top:100%; left:0; right:0; z-index:59;
    background:var(--navy-panel); border-bottom:1px solid rgba(255,255,255,.08);
    overflow:hidden; height:0;
  }
  .mega__inner{ padding:32px 24px; }
  .mega__grid{ display:grid; grid-template-columns:repeat(auto-fill, minmax(200px, 1fr)); gap:16px; }
  .mega__card{
    display:flex; flex-direction:column; align-items:flex-start; gap:10px;
    padding:16px; border-radius:12px; background:rgba(255,255,255,.04); transition:background .2s;
  }
  .mega__card:hover{ background:rgba(255,255,255,.08); }
  .mega__logo{ display:inline-flex; align-items:center; justify-content:center; background:#fff; border-radius:8px; padding:8px 12px; }
  .mega__logo img{ height:24px; width:auto; max-width:90px; object-fit:contain; }
  .mega__name{ font-weight:700; color:var(--text); }
  .mega__role{ font-size:.82rem; color:var(--muted); }
  .mega__all{ display:inline-block; margin-top:24px; font-weight:600; color:var(--orange); }

  @media (max-width: 900px){
    .mega{ display:none; }
  }

  .navbar__toggle{ display:none; }
  .navbar__burger{
    display:none; flex-direction:column; justify-content:center; gap:5px;
    width:34px; height:34px; cursor:pointer; flex-shrink:0;
  }
  .navbar__burger span{
    display:block; width:100%; height:2px; background:var(--text); border-radius:2px;
    transition:transform .25s, opacity .25s;
  }

  @media (max-width: 900px){
    .navbar__burger{ display:flex; }
    .navbar__nav{
      position:fixed; inset:0 0 0 auto;
      flex-direction:column; align-items:stretch; gap:0;
      width:min(320px, 80vw); height:100vh;
      background:var(--navy-panel);
      padding:32px 28px;
      transform:translateX(100%);
      transition:transform .3s ease;
      box-shadow:-8px 0 32px rgba(0,0,0,.35);
    }
    .navbar__links{ flex-direction:column; align-items:flex-start; gap:20px; margin-bottom:28px; }
    .navbar__cta{ width:100%; text-align:center; }
    .navbar__mega-mobile{
      display:block; list-style:none; margin-top:12px; padding-left:16px;
      display:flex; flex-direction:column; gap:12px;
    }
    .navbar__mega-mobile a{ font-weight:500; font-size:.88rem; color:var(--muted); }
    .navbar__mega-mobile a:hover{ color:var(--text); }
    .navbar__toggle:checked ~ .navbar__nav{ transform:translateX(0); }
    .navbar__toggle:checked ~ .navbar__burger span:nth-child(1){ transform:translateY(7px) rotate(45deg); }
    .navbar__toggle:checked ~ .navbar__burger span:nth-child(2){ opacity:0; }
    .navbar__toggle:checked ~ .navbar__burger span:nth-child(3){ transform:translateY(-7px) rotate(-45deg); }
  }
</style>
