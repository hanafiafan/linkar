---
import { buildNavLinks } from '../lib/nav';
import type { SiteContent } from '../lib/content';

interface Props { content: SiteContent }
const { content } = Astro.props;
const links = buildNavLinks(content.programs.length, content.posts.length, content.settings.navLabels);
---
<nav class="fabnav" aria-label="Navigasi utama">
  <div class="fabnav__menu" id="fabMenu">
    <a href="/" class="fabnav__brand">
      <img src={content.settings.logoColor || '/images/brand/linkar-logo.png'} alt="LINKAR" />
    </a>
    <ul class="fabnav__links">
      {links.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
    <a href="/#contact" class="btn btn-primary fabnav__cta">{content.settings.ctaLabel}</a>
  </div>
  <button type="button" class="fabnav__btn" aria-expanded="false" aria-controls="fabMenu" aria-label="Buka menu navigasi">
    <span></span><span></span><span></span>
  </button>
</nav>

<style>
  .fabnav{ position:fixed; left:20px; bottom:20px; z-index:70; }

  .fabnav__btn{
    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:5px;
    width:54px; height:54px; border-radius:50%;
    background:var(--orange); border:0; cursor:pointer;
    box-shadow:0 8px 24px rgba(0,0,0,.45);
    transition:transform .2s ease;
  }
  .fabnav__btn:hover{ transform:scale(1.06); }
  .fabnav__btn span{
    display:block; width:20px; height:2px; background:#1c0d02; border-radius:2px;
    transition:transform .25s, opacity .25s;
  }
  .fabnav.is-open .fabnav__btn span:nth-child(1){ transform:translateY(7px) rotate(45deg); }
  .fabnav.is-open .fabnav__btn span:nth-child(2){ opacity:0; }
  .fabnav.is-open .fabnav__btn span:nth-child(3){ transform:translateY(-7px) rotate(-45deg); }

  .fabnav__menu{
    position:absolute; left:0; bottom:calc(100% + 14px);
    min-width:230px; padding:18px;
    background:var(--navy-panel);
    border:1px solid rgba(255,255,255,.1);
    border-radius:16px;
    box-shadow:0 16px 48px rgba(0,0,0,.5);
    opacity:0; visibility:hidden; transform:translateY(10px);
    transition:opacity .25s ease, transform .25s ease, visibility .25s;
  }
  .fabnav.is-open .fabnav__menu{ opacity:1; visibility:visible; transform:none; }

  .fabnav__brand{
    display:inline-flex; background:#fff; border-radius:10px; padding:6px 12px; margin-bottom:14px;
  }
  .fabnav__brand img{ height:34px; width:auto; }

  .fabnav__links{ list-style:none; display:flex; flex-direction:column; gap:12px; }
  .fabnav__links a{ font-weight:600; font-size:.95rem; color:var(--muted); transition:color .2s; }
  .fabnav__links a:hover{ color:var(--text); }

  .fabnav__cta{ display:block; text-align:center; margin-top:16px; padding:11px 22px; font-size:.9rem; }

  @media (prefers-reduced-motion: reduce){
    .fabnav__btn, .fabnav__btn span, .fabnav__menu{ transition:none; }
  }
</style>

<script>
  const nav = document.querySelector('.fabnav') as HTMLElement | null;
  const btn = document.querySelector('.fabnav__btn') as HTMLButtonElement | null;
  if (nav && btn) {
    const set = (open: boolean) => {
      nav.classList.toggle('is-open', open);
      btn.setAttribute('aria-expanded', String(open));
    };
    btn.addEventListener('click', () => set(!nav.classList.contains('is-open')));
    document.addEventListener('click', (e) => {
      if (!nav.contains(e.target as Node)) set(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') set(false);
    });
    nav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => set(false)));
  }
</script>
