---
import type { SiteContent } from '../lib/content';

interface Props { content: SiteContent }
const { content } = Astro.props;
const { commitments } = content.home;
---
<section id="commitment" class="section section--light commitments" data-bg="#ffffff">
  <div class="wrap">
    <h2 data-split>{commitments.title}</h2>

    <div class="cgrid" data-stagger>
      {commitments.cards.map((card, i) => (
        <div class="ccard">
          <span class="cno">{String(i + 1).padStart(2, '0')}</span>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .commitments h2{
    color:var(--ink);
    text-align:center;
    font-size:clamp(1.7rem, 3vw, 2.3rem);
    max-width:640px;
    margin:0 auto;
  }

  .cgrid{
    display:grid;
    grid-template-columns:1fr;
    gap:22px;
    margin-top:40px;
  }
  @media (min-width: 900px){
    .cgrid{ grid-template-columns:repeat(2, 1fr); }
  }

  .ccard{
    background:#fff;
    border:1px solid #e8eaf1;
    border-radius:var(--radius);
    padding:28px;
  }
  .cno{
    display:block;
    font-size:2.2rem;
    font-weight:800;
    color:rgba(19,24,43,.12);
    line-height:1;
  }
  .ccard h3{
    color:var(--ink);
    font-size:1.05rem;
    margin-top:8px;
  }
  .ccard p{
    color:var(--ink-muted);
    font-size:.95rem;
    margin-top:8px;
  }
</style>
