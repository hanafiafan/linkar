---
import { buildNavLinks } from '../lib/nav';
import type { SiteContent } from '../lib/content';

interface Props { content: SiteContent }
const { content } = Astro.props;
const links = buildNavLinks(content.programs.length, content.posts.length, content.settings.navLabels);
const year = 2026;
---
<footer class="footer" data-bg="#000000">
  <div class="wrap">
    <!-- Kinetic Marquee Tagline (Ignite Style Outline) -->
    <div class="footer-marquee" aria-hidden="true">
      <div class="footer-marquee__track">
        {[...Array(4)].map(() => (
          <span class="footer-marquee__item">Everyone can be everyone's gateway ✦ </span>
        ))}
      </div>
    </div>

    <!-- Minimal solid divider -->
    <div class="footer-divider"></div>

    <div class="footer__top">
      <p class="footer__tagline">{content.settings.footerTagline || "Ecosystem Enabler"}</p>
    </div>

    <div class="footer__grid">
      <div class="footer__col">
        <h3 class="footer__heading">Navigasi</h3>
        <ul>
          {links.map((link) => (
            <li><a href={link.href} class="footer__link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__heading">Layanan</h3>
        <ul>
          {content.home.services.cards.map((card) => (
            <li>{card.title}</li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__heading">Entitas Ekosistem</h3>
        <ul>
          {content.entities.map((entity) => (
            <li>{entity.name} <span class="footer__muted">— {entity.role}</span></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__heading">Hubungi</h3>
        <ul>
          <li><a href={`mailto:${content.settings.formEmail}`} class="footer__link">{content.settings.formEmail}</a></li>
          <li><a href="https://linkedin.com" target="_blank" class="footer__link">LinkedIn</a></li>
          <li><a href="https://instagram.com" target="_blank" class="footer__link">Instagram</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p>© {year} CV Rantai Usaha Nusantara · LINKAR — Ecosystem Enabler. All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #000000;
    color: rgba(255, 255, 255, 0.5);
    padding: 100px 0 40px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  }

  /* Kinetic Marquee outline style */
  .footer-marquee {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
    margin-bottom: 50px;
  }

  .footer-marquee__track {
    display: flex;
    width: max-content;
    animation: footer-scroll 25s linear infinite;
  }

  .footer-marquee__item {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 800;
    color: rgba(255, 255, 255, 0.05);
    letter-spacing: -0.01em;
    white-space: nowrap;
    padding-right: 40px;
    text-transform: uppercase;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.1);
  }

  @keyframes footer-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* Minimalist Divider */
  .footer-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin-bottom: 60px;
  }

  .footer__top {
    margin-bottom: 60px;
  }

  .footer__tagline {
    font-size: clamp(1.6rem, 3.5vw, 2.5rem);
    font-weight: 800;
    line-height: 1.25;
    color: #ffffff;
    max-width: 600px;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    padding-bottom: 60px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__heading {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 20px;
  }

  .footer__col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__col li {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .footer__link {
    color: rgba(255, 255, 255, 0.75);
    transition: color 0.3s ease, transform 0.3s ease;
    display: inline-block;
  }

  .footer__link:hover {
    color: var(--orange, #F26A21);
    transform: translateX(4px);
  }

  .footer__muted {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.3);
  }

  .footer__bottom {
    padding-top: 30px;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.35);
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 480px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
