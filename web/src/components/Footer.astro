---
import { buildNavLinks } from '../lib/nav';
import type { SiteContent } from '../lib/content';

interface Props { content: SiteContent }
const { content } = Astro.props;
const links = buildNavLinks(content.programs.length, content.posts.length);
const year = 2026;
---
<footer class="footer">
  <div class="wrap">
    <div class="footer__top">
      <a href="/" class="footer__brand" aria-label="LINKAR">
        <img src={content.settings.logoWhite || '/images/brand/linkar-logo-white.png'} alt="LINKAR" width="42" height="42" class="footer__logo" />
      </a>
      <p class="footer__tagline">{content.settings.footerTagline}</p>
    </div>

    <div class="footer__grid">
      <div class="footer__col">
        <h3 class="footer__heading">Navigasi</h3>
        <ul>
          {links.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__heading">Layanan</h3>
        <ul>
          {content.home.services.cards.map((card) => (
            <li>{card.title}</li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__heading">Entitas</h3>
        <ul>
          {content.entities.map((entity) => (
            <li>{entity.name} <span class="footer__muted">— {entity.role}</span></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__heading">Kontak</h3>
        <ul>
          <li><a href={`mailto:${content.settings.formEmail}`}>{content.settings.formEmail}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p>© {year} CV Rantai Usaha Nusantara · LINKAR — Ecosystem Enabler</p>
    </div>
  </div>
</footer>

<style>
  .footer{ background:#070c1d; color:var(--muted); padding:80px 0 32px; }

  .footer__top{ margin-bottom:56px; }
  .footer__logo{ height:42px; width:auto; display:block; margin-bottom:24px; }
  .footer__tagline{
    font-style:italic; font-weight:600; color:var(--text);
    font-size:clamp(1.4rem, 3vw, 2rem); max-width:22ch; line-height:1.3;
  }

  .footer__grid{
    display:grid; grid-template-columns:repeat(4, 1fr); gap:32px;
    padding-bottom:48px; border-bottom:1px solid rgba(255,255,255,.08);
  }
  .footer__heading{
    font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:1.5px;
    color:var(--text); margin-bottom:18px;
  }
  .footer__col ul{ list-style:none; display:flex; flex-direction:column; gap:12px; }
  .footer__col li{ font-size:.92rem; }
  .footer__col a{ transition:color .2s; }
  .footer__col a:hover{ color:var(--orange); }
  .footer__muted{ color:var(--muted); opacity:.8; }

  .footer__bottom{ padding-top:28px; font-size:.85rem; }

  @media (max-width: 700px){
    .footer__grid{ grid-template-columns:1fr; gap:36px; }
  }
</style>
