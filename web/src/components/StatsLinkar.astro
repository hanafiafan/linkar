---
import type { SiteContent } from '../lib/content';
import Odometer from './Odometer.astro';

interface Props { content: SiteContent }
const { content } = Astro.props;
const { linkarStats } = content.home;
---
<section id="stats" class="section stats" data-bg="#000000">
  <div class="wrap">
    <span class="kicker" data-reveal="pop">{linkarStats.kicker}</span>

    <div class="sgrid" data-stagger>
      {linkarStats.items.map((item) => (
        <div class="stat">
          <div class="big"><Odometer value={item.value} /></div>
          <p class="label">{item.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats{
    background:var(--navy);
  }

  .sgrid{
    display:grid;
    grid-template-columns:repeat(2, 1fr);
    gap:24px;
    margin-top:40px;
  }
  @media (min-width: 900px){
    .sgrid{ grid-template-columns:repeat(4, 1fr); }
  }

  .stat{
    text-align:center;
  }
  .big{
    font-size:clamp(2.6rem, 6vw, 4rem);
    font-weight:800;
    color:var(--orange);
  }
  .label{
    font-weight:600;
    color:var(--text);
    margin-top:8px;
  }
</style>
