---
// Ignite-inspired preloader: responsive layout with dynamic percentage counter and corner labels
---
<div class="home-loader_component" id="home-loader">
  <!-- Corner Labels -->
  <p class="home-loader_top-left">ECOSYSTEM</p>
  <p class="home-loader_top-right">TECHNOLOGY</p>
  <p class="home-loader_bottom-left">LINKAR®</p>
  <p class="home-loader_bottom-right"><span>© 2006 - 2026</span></p>

  <!-- Centered Percentage Counter -->
  <div class="home-loader_center-wrap">
    <div class="home-loader_counter">
      <span id="loader-percent">0</span><span>%</span>
    </div>
    <!-- Simple branding bolt or custom SVG loader -->
    <div class="home-loader_bolt-svg-wrap">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 56 193" class="home-loader_bolt-svg">
        <path d="M2.60875 0.5L16.1823 90.3916H0L52.5308 192.5L38.8487 102.75H55.2329L2.60875 0.5Z" stroke="currentColor" stroke-width="2" class="home-loader_bolt-path"></path>
      </svg>
    </div>
  </div>
</div>

<style>
  .home-loader_component {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: #000000;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    user-select: none;
    transition: transform 0.85s cubic-bezier(0.85, 0.09, 0.15, 0.91);
  }

  .home-loader_component.is-done {
    transform: translateY(-100%);
  }

  /* Corner Labels */
  .home-loader_top-left,
  .home-loader_top-right,
  .home-loader_bottom-left,
  .home-loader_bottom-right {
    position: absolute;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
  }

  .home-loader_top-left     { top: clamp(1.5rem, 5vw, 3rem); left: clamp(1.5rem, 5vw, 3rem); }
  .home-loader_top-right    { top: clamp(1.5rem, 5vw, 3rem); right: clamp(1.5rem, 5vw, 3rem); }
  .home-loader_bottom-left  { bottom: clamp(1.5rem, 5vw, 3rem); left: clamp(1.5rem, 5vw, 3rem); }
  .home-loader_bottom-right { bottom: clamp(1.5rem, 5vw, 3rem); right: clamp(1.5rem, 5vw, 3rem); }

  /* Centered Wrapper */
  .home-loader_center-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    position: relative;
  }

  .home-loader_counter {
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    display: flex;
    align-items: baseline;
  }

  .home-loader_bolt-svg-wrap {
    width: 32px;
    height: auto;
    opacity: 0.25;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.5s ease;
  }

  .home-loader_component.is-done .home-loader_bolt-svg-wrap {
    transform: translateY(-40px) scale(1.15);
    opacity: 1;
    color: var(--orange, #F26A21);
  }

  .home-loader_bolt-svg {
    width: 100%;
    height: auto;
  }
</style>

<script>
  import gsap from 'gsap';

  const loader = document.getElementById('home-loader');
  const percentText = document.getElementById('loader-percent');

  if (loader && percentText) {
    const data = { val: 0 };
    
    // Lock body scroll during loading
    document.body.style.overflow = 'hidden';
    
    // Animate percentage text from 0 to 100
    gsap.to(data, {
      val: 100,
      duration: 1.6,
      ease: 'power2.out',
      onUpdate: () => {
        percentText.textContent = Math.floor(data.val).toString();
      },
      onComplete: () => {
        // Once done, slide loader up
        setTimeout(() => {
          loader.classList.add('is-done');
          // Restore scrolling
          document.body.style.overflow = '';
          setTimeout(() => {
            loader.remove();
          }, 900);
        }, 300);
      }
    });
  }
</script>
