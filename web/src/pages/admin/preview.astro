---
import Base from '../../layouts/Base.astro';
import HomeSections from '../../components/HomeSections.astro';
import { getContent } from '../../lib/content';
import { isAuthenticated } from '../../lib/adminAuth';

export const prerender = false;

if (!isAuthenticated(Astro.cookies)) {
  return Astro.redirect('/admin');
}

// Render homepage dari draft.json — dipakai sebagai pratinjau di dalam CMS
const content = await getContent(true);
---
<Base title="LINKAR — Pratinjau Draf">
  <HomeSections content={content} />
</Base>
