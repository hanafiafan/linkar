---
import { getContent } from '../../lib/content';
import { isAuthenticated } from '../../lib/adminAuth';

export const prerender = false;

// Check authentication
if (!isAuthenticated(Astro.cookies)) {
  return Astro.redirect('/admin');
}

// Load draft data first, fallback to seed
const content = await getContent(true);
const vis = content.home.visibility ?? {};

// Urutan section = urutan tampil di halaman utama
const NAV_GROUPS = [
  {
    label: 'Konten Halaman Utama',
    items: [
      { key: 'hero', num: '1', label: 'Hero (Pembuka)' },
      { key: 'marquee', num: '2', label: 'Marquee Ekosistem' },
      { key: 'about', num: '3', label: 'Tentang Kami' },
      { key: 'portfolio', num: '4', label: 'Portofolio' },
      { key: 'services', num: '5', label: 'Layanan' },
      { key: 'stats', num: '6', label: 'Dalam Angka' },
      { key: 'industry', num: '7', label: 'Peluang Industri' },
      { key: 'commitments', num: '8', label: 'Komitmen' },
      { key: 'cta', num: '9', label: 'Form Kontak' },
    ],
  },
  {
    label: 'Data & Pengaturan',
    items: [
      { key: 'entities', num: 'E', label: 'Entitas Ekosistem' },
      { key: 'programs', num: 'Pr', label: 'Program' },
      { key: 'posts', num: 'Bl', label: 'Blog' },
      { key: 'umum', num: 'P', label: 'Pengaturan Umum' },
    ],
  },
];
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>LINKAR CMS — Kelola Situs</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0a0a0c;
      --panel: #121216;
      --orange: #F26A21;
      --text: #eef1f8;
      --muted: #9aa3bd;
      --border: rgba(255, 255, 255, 0.08);
      --radius: 12px;
      --error: #ff5d2b;
      --ok: #2ecc71;
      --warn: #ffb347;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      background: var(--bg); color: var(--text);
      line-height: 1.6; height: 100vh;
      display: flex; flex-direction: column; overflow: hidden;
      font-size: 15px;
    }
    ::-webkit-scrollbar { width: 10px; height: 10px; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 8px; border: 2px solid var(--bg); }
    ::-webkit-scrollbar-track { background: transparent; }
    button { font-family: inherit; }
    button:focus-visible, input:focus-visible, textarea:focus-visible, select:focus-visible {
      outline: 2px solid var(--orange); outline-offset: 1px;
    }

    /* ===== Header ===== */
    header {
      background: var(--panel); border-bottom: 1px solid var(--border);
      padding: 10px 20px; display: flex; align-items: center; gap: 14px;
      flex-shrink: 0;
    }
    .header__title { display: flex; align-items: center; gap: 12px; }
    .header__logo { height: 30px; width: auto; background: white; padding: 3px 7px; border-radius: 6px; }
    .header__name { font-size: 0.98rem; font-weight: 800; display: block; line-height: 1.25; }
    .header__sub { font-size: 0.68rem; color: var(--muted); display: block; line-height: 1.25; letter-spacing: 0.3px; }
    .header__spacer { flex: 1; }

    .status {
      display: flex; align-items: center; gap: 8px;
      border: 1px solid var(--border); border-radius: 99px;
      padding: 5px 14px; font-size: 0.75rem; font-weight: 600; color: var(--muted);
      margin-left: 10px;
    }
    .status__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--ok); flex-shrink: 0; }
    .status.is-dirty { color: var(--warn); border-color: rgba(255, 179, 71, 0.35); }
    .status.is-dirty .status__dot { background: var(--warn); }

    .btn-ghost {
      background: transparent; border: 1px solid rgba(255, 255, 255, 0.18);
      color: var(--text); padding: 8px 15px; border-radius: 8px;
      font-weight: 600; font-size: 0.82rem; cursor: pointer; transition: background 0.2s, border-color 0.2s;
    }
    .btn-ghost:hover { background: rgba(255, 255, 255, 0.06); border-color: rgba(255, 255, 255, 0.3); }
    .btn-primary {
      background: linear-gradient(135deg, #F26A21, #ffb347); color: #1c0d02; border: 0;
      padding: 8px 17px; border-radius: 8px; font-weight: 700; font-size: 0.84rem;
      cursor: pointer; transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(242, 106, 33, 0.35); }
    button:disabled { opacity: 0.55; cursor: wait; transform: none !important; box-shadow: none !important; }

    /* Spinner untuk tombol yang sedang memproses */
    .spin {
      display: inline-block; width: 12px; height: 12px; margin-right: 7px;
      border: 2px solid currentColor; border-top-color: transparent; border-radius: 50%;
      animation: spin 0.7s linear infinite; vertical-align: -1px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ===== Layout 3 kolom ===== */
    .main {
      display: grid; grid-template-columns: 258px minmax(420px, 1fr) minmax(380px, 42%);
      grid-template-rows: minmax(0, 1fr);
      flex: 1; min-height: 0; overflow: hidden;
    }
    .main > * { min-height: 0; }
    @media (max-width: 1100px) {
      body { height: auto; overflow: auto; }
      .main { grid-template-columns: 1fr; grid-template-rows: none; overflow: visible; }
      .preview { height: 70vh; border-left: 0; border-top: 1px solid var(--border); }
    }

    /* ===== Sidebar ===== */
    .nav {
      border-right: 1px solid var(--border); background: rgba(14, 16, 24, 0.7);
      padding: 12px 12px 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 2px;
    }
    .nav-group {
      font-size: 0.64rem; font-weight: 800; letter-spacing: 1.4px; text-transform: uppercase;
      color: rgba(154, 163, 189, 0.65); padding: 16px 12px 7px;
    }
    .nav-btn {
      background: transparent; border: 0; color: var(--muted);
      padding: 9px 12px; border-radius: 8px; font-weight: 600; font-size: 0.86rem;
      text-align: left; cursor: pointer; transition: background 0.2s, color 0.2s;
      display: flex; align-items: center; gap: 10px;
    }
    .nav-btn:hover { background: rgba(255, 255, 255, 0.04); color: var(--text); }
    .nav-btn.is-active { background: rgba(242, 106, 33, 0.12); color: var(--orange); }
    .num {
      width: 22px; height: 22px; border-radius: 6px; flex-shrink: 0;
      background: rgba(255, 255, 255, 0.05); border: 1px solid var(--border);
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 0.66rem; font-weight: 800; color: var(--muted);
    }
    .nav-btn.is-active .num { background: rgba(242, 106, 33, 0.18); border-color: rgba(242, 106, 33, 0.4); color: var(--orange); }
    .off-tag {
      font-size: 0.6rem; font-weight: 800; letter-spacing: 0.5px; color: var(--muted);
      border: 1px solid var(--border); padding: 1px 6px; border-radius: 5px; margin-left: auto;
    }
    .nav-btn .dot {
      width: 8px; height: 8px; border-radius: 50%; background: var(--warn);
      margin-left: auto; flex-shrink: 0; display: none;
    }
    .off-tag ~ .dot, .off-tag + .dot { margin-left: 6px; }
    .nav-btn.is-dirty .dot { display: block; }

    /* ===== Editor ===== */
    .editor { overflow-y: auto; padding: 26px 30px; }
    .panel { display: none; flex-direction: column; gap: 20px; max-width: 860px; }
    .panel.is-active { display: flex; animation: fadein 0.18s ease; }
    @keyframes fadein { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
    .panel__head { display: flex; align-items: flex-start; gap: 16px; border-bottom: 1px solid var(--border); padding-bottom: 14px; }
    .panel__head h2 { font-size: 1.3rem; font-weight: 800; letter-spacing: -0.01em; }
    .panel__desc { color: var(--muted); font-size: 0.84rem; }
    .panel__head-main { flex: 1; }

    .note {
      color: var(--muted); font-size: 0.8rem; border: 1px dashed var(--border);
      border-radius: 8px; padding: 9px 13px; background: rgba(255, 255, 255, 0.015);
    }

    .field { display: flex; flex-direction: column; gap: 5px; position: relative; }
    .btn-upload {
      position: absolute; right: 5px; bottom: 5px;
      background: rgba(242, 106, 33, 0.14); border: 1px solid rgba(242, 106, 33, 0.4);
      color: var(--orange); padding: 4px 10px; border-radius: 6px;
      font-weight: 700; font-size: 0.68rem; cursor: pointer; transition: background 0.2s;
    }
    .btn-upload:hover { background: rgba(242, 106, 33, 0.25); }
    .field:has(.btn-upload) input { padding-right: 78px; }
    .field .help ~ .btn-upload, .field:has(.help) .btn-upload { bottom: 27px; }
    .field label { font-size: 0.74rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; }
    .field .help { font-size: 0.74rem; color: var(--muted); font-weight: 400; text-transform: none; letter-spacing: 0; }
    .field input, .field textarea, .field select {
      background: rgba(255, 255, 255, 0.04); border: 1px solid var(--border);
      border-radius: 8px; padding: 10px 13px; color: var(--text);
      font-family: inherit; font-size: 0.92rem; width: 100%;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .field input:focus, .field textarea:focus, .field select:focus {
      outline: none; border-color: var(--orange); box-shadow: 0 0 0 3px rgba(242, 106, 33, 0.15);
    }
    .grid2 { display: grid; grid-template-columns: 1fr; gap: 14px; }
    .grid3 { display: grid; grid-template-columns: 1fr; gap: 14px; }
    @media (min-width: 768px) {
      .grid2 { grid-template-columns: repeat(2, 1fr); }
      .grid3 { grid-template-columns: repeat(3, 1fr); }
    }

    /* Toggle switch */
    .vis-switch { display: flex; align-items: center; gap: 8px; cursor: pointer; flex-shrink: 0; }
    .vis-switch .vis-label { font-size: 0.76rem; font-weight: 700; color: var(--muted); }
    .switch { position: relative; display: inline-block; width: 42px; height: 22px; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider {
      position: absolute; cursor: pointer; inset: 0; background-color: rgba(255, 255, 255, 0.12);
      transition: .25s; border-radius: 22px;
    }
    .slider:before {
      position: absolute; content: ""; height: 14px; width: 14px; left: 4px; bottom: 4px;
      background-color: white; transition: .25s; border-radius: 50%;
    }
    input:checked + .slider { background-color: var(--orange); }
    input:checked + .slider:before { transform: translateX(20px); }

    /* Baris CRUD */
    .rows { display: flex; flex-direction: column; gap: 14px; }
    .row {
      display: flex; gap: 16px; align-items: flex-start; position: relative;
      border: 1px solid var(--border); border-radius: var(--radius);
      padding: 16px; padding-right: 46px; background: rgba(255, 255, 255, 0.02);
      transition: border-color 0.2s;
    }
    .row:hover { border-color: rgba(255, 255, 255, 0.16); }
    .row__fields { flex: 1; display: flex; flex-direction: column; gap: 12px; }
    .thumb {
      width: 72px; height: 72px; border-radius: 8px; overflow: hidden; flex-shrink: 0;
      border: 1px solid var(--border); background: #fff;
      display: flex; align-items: center; justify-content: center;
    }
    .thumb img { width: 100%; height: 100%; object-fit: contain; }
    .thumb--photo { background: var(--bg); }
    .thumb--photo img { object-fit: cover; }
    .thumb--missing { border-color: var(--error); box-shadow: 0 0 0 1px var(--error); }
    /* Foto portofolio dapat preview besar */
    #list-photos > .row > .thumb { width: 116px; height: 116px; }

    /* Field gambar dengan preview di sampingnya */
    .img-row { display: flex; gap: 10px; align-items: center; }
    .img-row .thumb { width: 46px; height: 46px; flex-shrink: 0; }
    .img-row input { flex: 1; }

    /* Strip preview galeri (satu gambar per baris teks) */
    .gallery-strip { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 6px; }
    .gallery-strip img {
      width: 64px; height: 64px; object-fit: cover; border-radius: 6px;
      border: 1px solid var(--border); background: var(--bg);
    }
    .row-del {
      position: absolute; top: 12px; right: 12px;
      background: transparent; border: 1px solid var(--border); color: var(--muted);
      width: 26px; height: 26px; border-radius: 6px; cursor: pointer;
      font-size: 0.8rem; line-height: 1; transition: all 0.2s;
    }
    .row-del:hover { background: var(--error); border-color: var(--error); color: #fff; }
    .check { display: flex; align-items: center; gap: 9px; font-size: 0.85rem; cursor: pointer; margin-top: 26px; }
    .check input { width: 18px; height: 18px; cursor: pointer; }

    .btn-add {
      background: transparent; border: 1px dashed var(--orange); color: var(--orange);
      padding: 10px 18px; border-radius: 8px; font-weight: 700; font-size: 0.83rem;
      cursor: pointer; transition: background .2s; align-self: flex-start;
    }
    .btn-add:hover { background: rgba(242, 106, 33, 0.08); }

    /* ===== Kartu entitas (collapse/expand) ===== */
    details.entity { display: block; padding: 0; }
    .entity__head {
      display: flex; align-items: center; gap: 14px;
      padding: 13px 16px; cursor: pointer; list-style: none; user-select: none;
    }
    .entity__head::-webkit-details-marker { display: none; }
    .entity__head::marker { content: ''; }
    .thumb--sm { width: 46px; height: 46px; border-radius: 8px; }
    .entity__title { flex: 1; min-width: 0; display: flex; flex-direction: column; line-height: 1.4; }
    .entity__name { font-weight: 700; font-size: 0.95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .entity__role { font-size: 0.74rem; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .entity__badge {
      font-size: 0.62rem; font-weight: 800; letter-spacing: 0.5px; flex-shrink: 0;
      border: 1px solid rgba(242, 106, 33, 0.4); color: var(--orange);
      padding: 2px 8px; border-radius: 99px;
    }
    .entity .row-del { position: static; flex-shrink: 0; }
    .entity__chev {
      color: var(--muted); font-size: 0.8rem; flex-shrink: 0;
      transition: transform 0.2s; margin-left: 2px;
    }
    details[open] .entity__chev { transform: rotate(180deg); }
    details[open] .entity__head { border-bottom: 1px solid var(--border); }
    .entity__body { padding: 16px; display: flex; flex-direction: column; gap: 12px; }

    h3.sub { font-size: 1.02rem; font-weight: 700; color: var(--orange); margin-top: 10px; }

    /* Panel action bar */
    .panel__actions {
      display: flex; gap: 12px; align-items: center;
      border-top: 1px solid var(--border); padding-top: 18px; margin-top: 8px;
    }
    .panel__actions .hint { font-size: 0.75rem; color: var(--muted); flex: 1; }

    /* ===== Preview ===== */
    .preview { border-left: 1px solid var(--border); display: flex; flex-direction: column; background: #08080b; }
    .preview__bar {
      display: flex; align-items: center; gap: 10px; padding: 8px 14px;
      border-bottom: 1px solid var(--border); flex-shrink: 0; background: var(--panel);
    }
    .preview__bar .badge {
      background: rgba(242, 106, 33, 0.15); border: 1px solid var(--orange);
      color: var(--orange); font-size: 0.66rem; font-weight: 800;
      padding: 3px 8px; border-radius: 6px; text-transform: uppercase; letter-spacing: 1px;
      flex-shrink: 0;
    }
    .preview__bar .info { font-size: 0.7rem; color: var(--muted); flex: 1; min-width: 0; }
    .preview__bar .btn-ghost { padding: 5px 11px; font-size: 0.72rem; flex-shrink: 0; }
    .seg { display: flex; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; flex-shrink: 0; }
    .seg__btn {
      background: transparent; border: 0; color: var(--muted); cursor: pointer;
      padding: 5px 11px; font-size: 0.72rem; font-weight: 700; transition: all 0.2s;
    }
    .seg__btn + .seg__btn { border-left: 1px solid var(--border); }
    .seg__btn.is-active { background: rgba(242, 106, 33, 0.15); color: var(--orange); }
    .preview__stage { flex: 1; display: flex; justify-content: center; overflow: hidden; }
    .preview iframe { border: 0; width: 100%; height: 100%; background: #000; }
    .preview.is-mobile .preview__stage { padding: 16px 0; }
    .preview.is-mobile iframe { width: 390px; border: 1px solid rgba(255, 255, 255, 0.14); border-radius: 18px; }

    /* ===== Modal konfirmasi ===== */
    .modal-backdrop {
      position: fixed; inset: 0; background: rgba(0, 0, 0, 0.65);
      backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px);
      display: none; align-items: center; justify-content: center; z-index: 1000;
    }
    .modal-backdrop.is-open { display: flex; }
    .modal {
      background: var(--panel); border: 1px solid var(--border); border-radius: 14px;
      padding: 26px 28px; width: min(430px, calc(100vw - 40px));
      box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
      animation: fadein 0.15s ease;
    }
    .modal h3 { font-size: 1.05rem; font-weight: 800; margin-bottom: 8px; }
    .modal p { font-size: 0.86rem; color: var(--muted); margin-bottom: 22px; }
    .modal__actions { display: flex; gap: 10px; justify-content: flex-end; }

    /* Toast */
    .toast {
      position: fixed; bottom: 22px; left: 50%; transform: translateX(-50%) translateY(80px);
      background: #0f1f14; border: 1px solid rgba(46, 204, 113, 0.6); color: #d6ffd6;
      padding: 12px 22px; border-radius: 10px; font-weight: 600; font-size: 0.88rem;
      opacity: 0; transition: all 0.3s; z-index: 1100; pointer-events: none;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
    }
    .toast.is-visible { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast.toast--error { background: #1f0f0f; border-color: var(--error); color: #ffd6c9; }
  </style>
</head>
<body>
  <header>
    <div class="header__title">
      <img src="/images/brand/linkar-logo.png" alt="" class="header__logo" />
      <div>
        <span class="header__name">LINKAR CMS</span>
        <span class="header__sub">Pengelola Konten Situs</span>
      </div>
    </div>
    <div class="status" id="save-status">
      <span class="status__dot"></span>
      <span id="save-status-text">Semua perubahan tersimpan</span>
    </div>
    <div class="header__spacer"></div>
    <button class="btn-ghost" id="btn-discard" type="button">Buang Draf</button>
    <button class="btn-ghost" id="btn-open-site" type="button">Buka Situs Live ↗</button>
    <button class="btn-primary" id="btn-publish-all" type="button">Terbitkan Semua</button>
    <button class="btn-ghost" id="btn-logout" type="button">Keluar</button>
  </header>

  <div class="main">
    <!-- ===== SIDEBAR: urutan sama dengan halaman utama ===== -->
    <nav class="nav">
      {NAV_GROUPS.map((group, gi) => (
        <>
          <p class="nav-group">{group.label}</p>
          {group.items.map((n, i) => (
            <button class:list={['nav-btn', { 'is-active': gi === 0 && i === 0 }]} data-section={n.key} type="button">
              <span class="num">{n.num}</span> {n.label}
              <span class="off-tag" style="display:none">Nonaktif</span>
              <span class="dot"></span>
            </button>
          ))}
        </>
      ))}
    </nav>

    <!-- ===== EDITOR ===== -->
    <div class="editor" id="editor">

      <!-- HERO -->
      <section class="panel is-active" id="panel-hero" data-key="hero">
        <div class="panel__head">
          <div class="panel__head-main">
            <h2>Hero — Bagian Pembuka</h2>
            <p class="panel__desc">Bagian paling atas situs: teks pembuka besar, deskripsi, dan dua tombol.</p>
          </div>
          <label class="vis-switch">
            <span class="vis-label">Tampil di situs</span>
            <span class="switch"><input type="checkbox" id="vis-hero" checked={vis.hero !== false} /><span class="slider"></span></span>
          </label>
        </div>
        <div class="field">
          <label>Teks Badge Kecil (di atas judul)</label>
          <input type="text" id="hero-badge" value={content.home.hero.badge} />
        </div>
        <p class="note">ℹ️ Judul besar hero memakai teks berputar tetap: "Menghubungkan komunitas, korporat, dan pemerintah dalam satu <b>EKOSISTEM. / KOLABORASI. / LINGKAR DAMPAK.</b>" — bagian ini diatur di desain, bukan lewat CMS.</p>
        <div class="field">
          <label>Kalimat Bahasa Inggris (miring)</label>
          <input type="text" id="hero-sub-en" value={content.home.hero.subEn} />
        </div>
        <div class="field">
          <label>Deskripsi Bahasa Indonesia</label>
          <textarea id="hero-sub-id" rows="3">{content.home.hero.subId}</textarea>
        </div>
        <div class="grid2">
          <div class="field">
            <label>Tombol Utama</label>
            <input type="text" id="hero-cta-p" value={content.home.hero.primaryCta} />
          </div>
          <div class="field">
            <label>Tombol Kedua</label>
            <input type="text" id="hero-cta-s" value={content.home.hero.secondaryCta} />
          </div>
        </div>
        <div class="grid2">
          <div class="field">
            <label>Visual di Sisi Kanan Hero</label>
            <select id="hero-visual">
              <option value="logo3d" selected={content.home.hero.visualMode === 'logo3d'}>Logo 3D Interaktif</option>
              <option value="foto" selected={content.home.hero.visualMode === 'foto'}>Satu Foto</option>
              <option value="folder" selected={content.home.hero.visualMode === 'folder'}>Galeri Folder</option>
              <option value="kosong" selected={content.home.hero.visualMode === 'kosong'}>Kosong</option>
            </select>
          </div>
          <div class="field">
            <label>Gambar Hero (dipakai jika mode "Satu Foto")</label>
            <div class="img-row">
