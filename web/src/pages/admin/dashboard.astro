    // Attach Save Draft events
    document.querySelectorAll('.btn-save-draft').forEach(btn => {
      btn.addEventListener('click', async () => {
        const scope = btn.getAttribute('data-scope');
        const payload = getEditorPayload();
        try {
          const res = await fetch('/api/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          if (res.ok) {
            showToast(`Draf bagian ${scope?.toUpperCase()} berhasil disimpan!`);
          } else {
            const data = await res.json();
            showToast(data.error || 'Gagal menyimpan draf', true);
          }
        } catch (err) {
          showToast('Gagal menghubungi server', true);
        }
      });
    });

    // Attach Publish events
    document.querySelectorAll('.btn-publish').forEach(btn => {
      btn.addEventListener('click', async () => {
        const scope = btn.getAttribute('data-scope');
        if (!scope || !confirm(`Apakah Anda yakin ingin mempublikasikan bagian ${scope.toUpperCase()} ke Live Website?`)) return;

        // Save current draft first
        const payload = getEditorPayload();
        try {
          const saveRes = await fetch('/api/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          if (!saveRes.ok) {
            showToast('Gagal menyimpan draf sebelum publikasi', true);
            return;
          }

          // Publish with scope parameter
          const pubRes = await fetch('/api/publish', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ scope: scope })
          });

          if (pubRes.ok) {
            showToast(`Sukses! Bagian ${scope.toUpperCase()} telah dipublikasikan ke Live Website! 🚀`);
          } else {
            const data = await pubRes.json();
            showToast(data.error || 'Gagal mempublikasikan', true);
          }
        } catch (err) {
          showToast('Gagal menghubungi server', true);
        }
      });
    });
  </script>
</body>
</html>
