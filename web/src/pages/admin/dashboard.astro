  <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp,image/gif,image/svg+xml" style="display:none" />

  <div class="toast" id="toast">Perubahan draf berhasil disimpan!</div>

  <script is:inline type="application/json" id="base-content" set:html={JSON.stringify(content).replace(/</g, '\\u003c')}></script>

  <script>
    // ===== Base content dari server: payload di-merge dari sini agar data
    // yang tidak diedit CMS (programs, posts, dll) tidak pernah tertimpa. =====
    const baseContent = JSON.parse(document.getElementById('base-content')?.textContent || '{}');

    const val = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement).value;
    const isOn = (id: string) => (document.getElementById(id) as HTMLInputElement).checked;

    // ===== Navigasi section =====
    // Selector section di halaman utama — pratinjau ikut scroll ke sini
    const PREVIEW_ANCHORS: Record<string, string> = {
      hero: '.hero', marquee: '#ecosystem', about: '#about', portfolio: '#portfolio',
      services: '#sectionDrive', stats: '#stats', industry: '#opportunity',
      commitments: '#commitment', cta: '#contact',
    };

    const navBtns = document.querySelectorAll('.nav-btn');
    navBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.getAttribute('data-section') || '';
        navBtns.forEach(b => b.classList.remove('is-active'));
        document.querySelectorAll('.panel').forEach(p => p.classList.remove('is-active'));
        btn.classList.add('is-active');
        document.getElementById(`panel-${key}`)?.classList.add('is-active');
        document.getElementById('editor')?.scrollTo({ top: 0 });
        // Scroll pratinjau ke section yang sedang diedit
        const sel = PREVIEW_ANCHORS[key];
        if (sel) {
          try {
            (document.getElementById('site-preview') as HTMLIFrameElement)
              ?.contentDocument?.querySelector(sel)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          } catch { /* iframe belum siap — abaikan */ }
        }
      });
    });

    // ===== Status simpan & penanda perubahan (dirty) =====
    const dirty = new Set<string>();
    let lastSavedAt = '';

    function updateStatus() {
      const chip = document.getElementById('save-status');
      const txt = document.getElementById('save-status-text');
      if (!chip || !txt) return;
      if (dirty.size > 0) {
        chip.classList.add('is-dirty');
        txt.textContent = `${dirty.size} bagian belum disimpan · tekan Ctrl+S`;
      } else {
        chip.classList.remove('is-dirty');
        txt.textContent = lastSavedAt ? `Draf tersimpan · ${lastSavedAt}` : 'Semua perubahan tersimpan';
      }
    }

    function markDirty(el: Element | null) {
      const key = el?.closest('.panel')?.getAttribute('data-key');
      if (!key) return;
      dirty.add(key);
      document.querySelector(`.nav-btn[data-section="${key}"]`)?.classList.add('is-dirty');
      updateStatus();
    }
    function clearDirty() {
      dirty.clear();
      navBtns.forEach(b => b.classList.remove('is-dirty'));
      lastSavedAt = new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
      updateStatus();
    }

    // Ingatkan sebelum menutup tab kalau masih ada perubahan belum disimpan
    window.addEventListener('beforeunload', (e) => {
      if (dirty.size > 0) e.preventDefault();
    });

    // Tag "Nonaktif" di sidebar untuk section yang disembunyikan
    function syncOffTags() {
      document.querySelectorAll('.panel').forEach(p => {
        const cb = p.querySelector('.vis-switch input') as HTMLInputElement | null;
        const key = p.getAttribute('data-key');
        const tag = document.querySelector(`.nav-btn[data-section="${key}"] .off-tag`) as HTMLElement | null;
        if (cb && tag) tag.style.display = cb.checked ? 'none' : '';
      });
    }

    document.addEventListener('input', (e) => {
      const t = e.target as HTMLInputElement;
      markDirty(t);
      // Sinkronkan thumbnail saat alamat gambar/logo diubah
      if (t.dataset?.f === 'src' || t.dataset?.f === 'logo') {
        const img = t.closest('.row')?.querySelector('.thumb img') as HTMLImageElement | null;
        if (img && t.value) img.src = t.value;
      }
      // Sinkronkan judul kartu (entitas/program/artikel) saat diketik
      if (t.dataset?.f === 'name' || t.dataset?.f === 'title') {
        const head = t.closest('.entity')?.querySelector('.entity__name');
        if (head) head.textContent = t.value || 'Tanpa Judul';
      }
      if (t.dataset?.f === 'role') {
        const head = t.closest('.entity')?.querySelector('.entity__role');
        if (head) head.textContent = t.value;
      }
      // Cover di kartu program/artikel ikut memperbarui thumbnail
      if (t.dataset?.f === 'cover') {
        const img = t.closest('.row')?.querySelector('.thumb img') as HTMLImageElement | null;
        if (img && t.value) img.src = t.value;
      }
      // Preview gambar hero
      if (t.id === 'hero-image') {
        const img = document.getElementById('hero-image-thumb') as HTMLImageElement | null;
        if (img && t.value) img.src = t.value;
      }
      // Strip preview galeri mengikuti isi textarea (satu gambar per baris)
      if (t.dataset?.f === 'gallery') {
        const strip = t.closest('.field')?.querySelector('.gallery-strip');
        if (strip) {
          strip.innerHTML = '';
          t.value.split('\n').map(s => s.trim()).filter(Boolean).forEach(src => {
            const img = document.createElement('img');
            img.src = src;
            img.onerror = () => { img.src = '/favicon.png'; };
            strip.appendChild(img);
          });
        }
      }
      // Slug terisi otomatis dari judul — hanya jika slug masih kosong
      // atau hasil isian otomatis (tidak menimpa slug lama yang sudah punya URL)
      if (t.dataset?.f === 'title') {
        const slug = t.closest('.entity__body')?.querySelector('[data-f="slug"]') as HTMLInputElement | null;
        if (slug && (slug.value === '' || slug.dataset.auto === '1')) {
          slug.value = t.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
          slug.dataset.auto = '1';
        }
      }
      // Slug yang diketik manual berhenti mengikuti judul
      if (t.dataset?.f === 'slug') delete t.dataset.auto;
    });
    document.addEventListener('change', (e) => {
      markDirty(e.target as Element);
      syncOffTags();
    });
    syncOffTags();

    // Tandai thumbnail merah kalau gambarnya tidak ditemukan (404)
    document.addEventListener('error', (e) => {
      const img = e.target as HTMLElement;
      if (img.tagName === 'IMG') img.closest('.thumb')?.classList.add('thumb--missing');
    }, true);
    document.addEventListener('load', (e) => {
      const img = e.target as HTMLImageElement;
      if (img.tagName === 'IMG' && !img.src.endsWith('/favicon.png')) {
        img.closest('.thumb')?.classList.remove('thumb--missing');
      }
    }, true);

    // ===== Modal konfirmasi (pengganti confirm bawaan browser) =====
    const modal = document.getElementById('modal');
    let modalResolve: ((v: boolean) => void) | null = null;

    function confirmDialog(title: string, body: string, okLabel = 'Ya, Lanjutkan'): Promise<boolean> {
      (document.getElementById('modal-title') as HTMLElement).textContent = title;
      (document.getElementById('modal-body') as HTMLElement).textContent = body;
      (document.getElementById('modal-ok') as HTMLElement).textContent = okLabel;
      modal?.classList.add('is-open');
      return new Promise(res => { modalResolve = res; });
    }
    function closeModal(result: boolean) {
      modal?.classList.remove('is-open');
      modalResolve?.(result);
      modalResolve = null;
    }
    document.getElementById('modal-ok')?.addEventListener('click', () => closeModal(true));
    document.getElementById('modal-cancel')?.addEventListener('click', () => closeModal(false));
    modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(false); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal?.classList.contains('is-open')) closeModal(false);
    });

    // ===== Status sibuk pada tombol =====
    function setBusy(btn: HTMLButtonElement, busy: boolean, busyLabel = 'Memproses…') {
      if (busy) {
        btn.dataset.label = btn.textContent || '';
        btn.innerHTML = `<span class="spin"></span>${busyLabel}`;
        btn.disabled = true;
      } else {
        btn.textContent = btn.dataset.label || btn.textContent;
        btn.disabled = false;
      }
    }

    // ===== Unggah gambar: tombol "Unggah" otomatis di setiap field gambar =====
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    let uploadTarget: HTMLInputElement | null = null;

    function injectUploadButtons() {
      document.querySelectorAll('input[data-f="src"], input[data-f="logo"], input[data-f="cover"], #hero-image').forEach(el => {
        const inp = el as HTMLInputElement;
        if (inp.dataset.hasUpload) return;
        inp.dataset.hasUpload = '1';
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'btn-upload';
        btn.textContent = 'Unggah';
        btn.title = 'Unggah gambar dari komputer';
        btn.addEventListener('click', () => { uploadTarget = inp; fileInput.click(); });
        inp.insertAdjacentElement('afterend', btn);
      });
    }
    injectUploadButtons();

    fileInput.addEventListener('change', async () => {
      const file = fileInput.files?.[0];
      fileInput.value = '';
      if (!file || !uploadTarget) return;
      const fd = new FormData();
      fd.append('file', file);
      showToast('Mengunggah gambar…');
      try {
        const res = await fetch('/api/upload', { method: 'POST', body: fd });
        const data = await res.json();
        if (res.ok) {
          uploadTarget.value = data.path;
          uploadTarget.dispatchEvent(new Event('input', { bubbles: true }));
          showToast(data.pending
            ? '✓ Gambar dikirim ke GitHub — akan tampil di pratinjau setelah build selesai (~1-2 menit), lalu Simpan Draf.'
            : '✓ Gambar terunggah — jangan lupa Simpan Draf.');
        } else {
          showToast(data.error || 'Gagal mengunggah gambar', true);
        }
      } catch {
        showToast('Gagal menghubungi server', true);
      }
    });

    // ===== CRUD: tambah & hapus baris =====
    document.querySelectorAll('.btn-add').forEach(btn => {
      btn.addEventListener('click', () => {
        const name = btn.getAttribute('data-add');
        const tpl = document.getElementById(`tpl-${name}`) as HTMLTemplateElement;
        const list = document.getElementById(`list-${name}`);
        if (tpl && list) {
          list.appendChild(tpl.content.cloneNode(true));
          markDirty(btn);
          injectUploadButtons();
          (list.lastElementChild?.querySelector('input, textarea') as HTMLElement)?.focus();
        }
      });
    });

    document.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('row-del')) {
        e.preventDefault(); // jangan buka/tutup kartu <details> saat tombol hapus diklik
        const row = target.closest('.row');
        if (row && await confirmDialog('Hapus item ini?', 'Item akan hilang dari draf setelah kamu menekan Simpan Draf. Situs live tidak berubah sampai kamu menerbitkannya.', 'Ya, Hapus')) {
          markDirty(row);
          row.remove();
        }
      }
    });

    // ===== Kumpulkan data baris CRUD =====
    function rowData(row: Element) {
      const o: Record<string, unknown> = {};
      row.querySelectorAll('[data-f]').forEach((el) => {
        const input = el as HTMLInputElement;
        const key = input.dataset.f as string;
        if (input.type === 'checkbox') o[key] = input.checked;
        else if (input.dataset.bool !== undefined) o[key] = input.value === 'true';
        else o[key] = input.value;
      });
      return o;
    }
    const listRows = (name: string) => Array.from(document.querySelectorAll(`#list-${name} > .row`));
    const listData = (name: string) => listRows(name).map(rowData);

    // ===== Susun payload lengkap (merge dari baseContent) =====
    function getPayload() {
      const payload = structuredClone(baseContent);

      Object.assign(payload.settings, {
        formEmail: val('set-email'),
        footerTagline: val('set-tagline'),
        ctaLabel: val('set-cta'),
        social: {
          linkedin: val('set-linkedin').trim(),
          instagram: val('set-instagram').trim(),
        },
      });

      payload.home.visibility = {
        hero: isOn('vis-hero'),
        marquee: isOn('vis-marquee'),
        about: isOn('vis-about'),
        portfolio: isOn('vis-portfolio'),
        services: isOn('vis-services'),
        linkarStats: isOn('vis-linkarStats'),
        industry: isOn('vis-industry'),
        commitments: isOn('vis-commitments'),
        cta: isOn('vis-cta'),
      };

      Object.assign(payload.home.hero, {
        badge: val('hero-badge'),
        subEn: val('hero-sub-en'),
        subId: val('hero-sub-id'),
        primaryCta: val('hero-cta-p'),
        secondaryCta: val('hero-cta-s'),
        visualMode: val('hero-visual'),
        heroImage: val('hero-image'),
        folderPhotos: val('hero-folder').split('\n').map(s => s.trim()).filter(Boolean),
      });

      payload.home.marquee = { kicker: val('marquee-kicker'), title: val('marquee-title') };

      payload.home.about.kicker = val('about-kicker');
      payload.home.about.paragraphs = listData('paragraphs').map(o => o.text);

      payload.home.portfolio.titleTop = val('port-top');
      payload.home.portfolio.intro = val('port-intro');
      payload.photos = listData('photos');

      Object.assign(payload.home.services, {
        kicker: val('svc-kicker'),
        title: val('svc-title'),
        differentiator: val('svc-diff'),
        cards: listData('svc'),
      });

      payload.home.linkarStats = { kicker: val('stats-kicker'), items: listData('stats') };

      payload.home.industry = {
        kicker: val('ind-kicker'),
        title: val('ind-title'),
        closing: val('ind-closing'),
        items: listData('ind'),
      };

      payload.home.commitments = { title: val('commit-title'), cards: listData('commit') };

      payload.home.cta = {
        title: val('cta-title'),
        subEn: val('cta-sub-en'),
        subId: val('cta-sub-id'),
        submitLabel: val('cta-submit'),
      };

      // Entitas: pertahankan field lama yang tidak ada di form (mis. heroImage, body)
      payload.entities = listRows('entities').map(row => {
        const origIdx = (row as HTMLElement).dataset.orig;
        const orig = origIdx !== undefined ? baseContent.entities[+origIdx] ?? {} : {};
        return { ...orig, ...rowData(row) };
      });

      // Program: galeri = satu path per baris; dampak = "angka | keterangan | catatan" per baris
      payload.programs = listRows('programs').map(row => {
        const origIdx = (row as HTMLElement).dataset.orig;
        const orig = origIdx !== undefined ? baseContent.programs[+origIdx] ?? {} : {};
        const d = rowData(row);
        return {
          ...orig, ...d,
          gallery: String(d.gallery ?? '').split('\n').map(s => s.trim()).filter(Boolean),
          impact: String(d.impact ?? '').split('\n').map(s => s.trim()).filter(Boolean).map(line => {
            const [value = '', label = '', note = ''] = line.split('|').map(s => s.trim());
            return note ? { value, label, note } : { value, label };
          }),
        };
      });

      payload.posts = listRows('posts').map(row => {
        const origIdx = (row as HTMLElement).dataset.orig;
        const orig = origIdx !== undefined ? baseContent.posts[+origIdx] ?? {} : {};
        return { ...orig, ...rowData(row) };
      });

      return payload;
    }

    // ===== Toast =====
    const toast = document.getElementById('toast');
    function showToast(message: string, isError = false) {
      if (!toast) return;
      toast.textContent = message;
      toast.classList.toggle('toast--error', isError);
      toast.classList.add('is-visible');
      setTimeout(() => toast.classList.remove('is-visible'), 3000);
    }

    // Di dev, menulis seed.json memicu reload halaman (HMR) yang bisa menelan
    // toast sukses — simpan pesannya supaya tetap tampil setelah reload.
    function showToastPersist(message: string) {
      sessionStorage.setItem('cms-toast', JSON.stringify({ message, at: Date.now() }));
      showToast(message);
    }
    try {
      const pending = JSON.parse(sessionStorage.getItem('cms-toast') || 'null');
      sessionStorage.removeItem('cms-toast');
      if (pending && Date.now() - pending.at < 10_000) showToast(pending.message);
    } catch { /* abaikan */ }

    // ===== Pratinjau =====
    const previewFrame = document.getElementById('site-preview') as HTMLIFrameElement;
    function reloadPreview() {
      previewFrame.src = '/admin/preview?t=' + Date.now();
    }
    document.getElementById('btn-reload-preview')?.addEventListener('click', reloadPreview);
    document.getElementById('btn-open-site')?.addEventListener('click', () => window.open('/', '_blank'));

    // Toggle ukuran layar pratinjau (desktop / HP)
    document.querySelectorAll('.seg__btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.seg__btn').forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        document.getElementById('preview')?.classList.toggle('is-mobile', btn.getAttribute('data-device') === 'mobile');
      });
    });

    // ===== Simpan draf =====
    async function saveDraft(): Promise<boolean> {
      try {
        const res = await fetch('/api/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(getPayload()),
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          showToast(data.error || 'Gagal menyimpan draf', true);
          return false;
        }
        clearDirty();
        reloadPreview();
        return true;
      } catch {
        showToast('Gagal menghubungi server', true);
        return false;
      }
    }

    document.querySelectorAll('.act-save').forEach(btn => {
      btn.addEventListener('click', async () => {
        const b = btn as HTMLButtonElement;
        setBusy(b, true, 'Menyimpan…');
        if (await saveDraft()) showToast('✓ Draf tersimpan — cek pratinjau di kanan.');
        setBusy(b, false);
      });
    });

    // Ctrl+S / Cmd+S = simpan draf
    document.addEventListener('keydown', async (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 's') {
        e.preventDefault();
        if (await saveDraft()) showToast('✓ Draf tersimpan — cek pratinjau di kanan.');
      }
    });

    // ===== Terbitkan =====
    async function publish(scope: string): Promise<void> {
      if (!(await saveDraft())) return;
      try {
        const res = await fetch('/api/publish', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ scope, draft: getPayload() }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok) {
          showToastPersist(data.github === 'pushed'
            ? '✓ Diterbitkan & dikirim ke GitHub — situs live ter-update setelah build selesai.'
            : '✓ Berhasil diterbitkan ke situs live.');
        } else {
          showToast(data.error || 'Gagal menerbitkan', true);
        }
      } catch {
        showToast('Gagal menghubungi server', true);
      }
    }

    document.querySelectorAll('.act-publish').forEach(btn => {
      btn.addEventListener('click', async () => {
        const b = btn as HTMLButtonElement;
        const scope = b.getAttribute('data-scope') || '';
        if (!(await confirmDialog('Terbitkan bagian ini?', 'Draf terbaru bagian ini akan langsung tampil untuk semua pengunjung situs.', 'Ya, Terbitkan'))) return;
        setBusy(b, true, 'Menerbitkan…');
        await publish(scope);
        setBusy(b, false);
      });
    });

    document.getElementById('btn-publish-all')?.addEventListener('click', async () => {
      const b = document.getElementById('btn-publish-all') as HTMLButtonElement;
      if (!(await confirmDialog('Terbitkan semua perubahan?', 'Seluruh isi draf akan menggantikan konten situs live — termasuk semua section, foto, dan entitas.', 'Ya, Terbitkan Semua'))) return;
      setBusy(b, true, 'Menerbitkan…');
      await publish('all');
      setBusy(b, false);
    });

    // ===== Buang draf: kembalikan draf ke isi situs live =====
    document.getElementById('btn-discard')?.addEventListener('click', async () => {
      const b = document.getElementById('btn-discard') as HTMLButtonElement;
      if (!(await confirmDialog('Buang semua perubahan draf?', 'Draf akan dikembalikan persis seperti isi situs live sekarang. Perubahan yang belum diterbitkan akan hilang.', 'Ya, Buang Draf'))) return;
      setBusy(b, true, 'Membuang…');
      try {
        const res = await fetch('/api/discard', { method: 'POST' });
        if (res.ok) {
          dirty.clear(); // jangan memicu peringatan beforeunload saat reload
          window.location.reload();
        } else {
          const data = await res.json().catch(() => ({}));
          showToast(data.error || 'Gagal membuang draf', true);
          setBusy(b, false);
        }
      } catch {
        showToast('Gagal menghubungi server', true);
        setBusy(b, false);
      }
    });

    // ===== Keluar =====
    document.getElementById('btn-logout')?.addEventListener('click', async () => {
      await fetch('/api/logout', { method: 'POST' });
      window.location.href = '/admin';
    });
  </script>
</body>
</html>
