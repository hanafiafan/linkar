---
import { toHTML } from '@portabletext/to-html';
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Odometer from '../../components/Odometer.astro';
import { getContent } from '../../lib/content';
import type { ProgramDoc, SiteContent } from '../../lib/content';

export async function getStaticPaths() {
  const content = await getContent();
  return content.programs.map((program) => ({ params: { slug: program.slug }, props: { program, content } }));
}

interface Props { program: ProgramDoc; content: SiteContent }
const { program, content } = Astro.props;

const paragraphs = typeof program.body === 'string' ? program.body.split(/\n\s*\n/) : null;
const ptHtml = paragraphs === null
  ? toHTML(program.body as never, { components: { types: { image: () => '<!-- pt-image: unresolved until Task 14 -->' } } })
  : null;

const gallery = (program.gallery ?? []).map((src) => ({ src, cap: program.title }));
---
<Base title={`${program.title} — LINKAR`} description={program.summary}>
  <Navbar content={content} />

  <section class="hero" style={`background-image:linear-gradient(rgba(10,17,40,.82),rgba(10,17,40,.82)),url('${program.cover}')`}>
    <div class="wrap">
      <h1>{program.title}</h1>
      <p class="meta">{program.partner} · {program.period} · {program.location}</p>
    </div>
  </section>

  {program.impact.length > 0 && (
    <section class="section impact">
      <div class="wrap">
        <div class="sgrid" data-stagger>
          {program.impact.map((stat) => (
            <div class="stat">
              <div class="big"><Odometer value={stat.value} /></div>
              <p class="label">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section body">
    <div class="wrap prose">
      {paragraphs !== null
        ? paragraphs.map((p) => <p>{p}</p>)
        : <div set:html={ptHtml} />}
    </div>
  </section>

  {gallery.length > 0 && (
    <section class="section gal">
      <div class="wrap">
        <div class="ggrid" data-stagger>
          {gallery.map((ph, i) => (
            <button class="gitem" data-lb-index={i} data-lb-src={ph.src} data-lb-cap={ph.cap} aria-label={`Perbesar foto: ${ph.cap}`}>
              <img src={ph.src} alt={ph.cap} loading="lazy" />
              <span class="duo" aria-hidden="true"></span>
            </button>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section cta">
    <div class="wrap">
      <h2>Punya program serupa?</h2>
      <a href="/#contact" class="btn btn-primary">Ajak Kolaborasi →</a>
    </div>
  </section>

  <Footer content={content} />
</Base>

<style>
  .hero{background-size:cover;background-position:center;padding:120px 0 80px}
  .hero h1{font-size:clamp(2.2rem,6vw,3.6rem);max-width:820px}
  .hero .meta{color:var(--muted);font-weight:600;margin-top:16px}

  .impact{padding:64px 0;background:var(--navy-panel)}
  .sgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;text-align:center}
  @media (min-width:900px){.sgrid{grid-template-columns:repeat(4,1fr)}}
  .big{font-size:clamp(2.6rem,6vw,4rem);font-weight:800;color:var(--orange)}
  .label{font-weight:600;color:var(--text);margin-top:8px}

  .body{padding:72px 0}
  .prose{max-width:780px}
  .prose :global(p){margin-bottom:1.2em;color:var(--text)}

  .gal{padding:0 0 72px}
  .ggrid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
  @media (min-width:900px){.ggrid{grid-template-columns:repeat(3,1fr)}}
  .gitem{position:relative;border-radius:12px;overflow:hidden;cursor:zoom-in;border:0;padding:0;background:none}
  .gitem img{width:100%;height:100%;aspect-ratio:4/3;object-fit:cover;filter:grayscale(1) contrast(1.05) brightness(.95);transition:filter .4s,transform .4s}
  .gitem .duo{position:absolute;inset:0;background:var(--navy-logo);mix-blend-mode:color;transition:opacity .4s}
  .gitem:hover img,.gitem:focus-visible img{filter:none;transform:scale(1.03)}
  .gitem:hover .duo,.gitem:focus-visible .duo{opacity:0}
  @media (prefers-reduced-motion: reduce){.gitem img,.gitem .duo{transition:none}}

  .cta{background:var(--navy-panel);text-align:center;padding:72px 0}
  .cta h2{font-size:clamp(1.8rem,4vw,2.6rem);margin-bottom:28px}
</style>
