---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProgramCard from '../../components/ProgramCard.astro';
import { getContent } from '../../lib/content';

const content = await getContent();
if (content.programs.length === 0) return Astro.redirect('/');
---
<Base title="Program — LINKAR" description="Program dan case study LINKAR — jejak eksekusi program berdampak bersama mitra korporat, pemerintah, dan komunitas.">
  <Navbar content={content} />
  <section class="section head">
    <div class="wrap">
      <span class="kicker">PROGRAM &amp; CASE STUDY</span>
      <h1>Jejak Program Kami</h1>
      <div class="grid" data-stagger>
        {content.programs.map((program) => <ProgramCard program={program} />)}
      </div>
    </div>
  </section>
  <Footer content={content} />
</Base>

<style>
  .head{padding-top:64px}
  h1{font-size:clamp(2rem,5vw,3rem);margin-top:20px}
  .grid{display:grid;grid-template-columns:1fr;gap:24px;margin-top:40px}
  @media (min-width:700px){.grid{grid-template-columns:repeat(2,1fr)}}
  @media (min-width:1000px){.grid{grid-template-columns:repeat(3,1fr)}}
</style>
