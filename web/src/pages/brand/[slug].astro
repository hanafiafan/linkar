---
import { toHTML } from '@portabletext/to-html';
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getContent } from '../../lib/content';
import type { Entity, SiteContent } from '../../lib/content';

export async function getStaticPaths() {
  const content = await getContent();
  return content.entities
    .filter((entity) => entity.hasProfile && entity.slug)
    .map((entity) => ({ params: { slug: entity.slug }, props: { entity, content } }));
}

interface Props { entity: Entity; content: SiteContent }
const { entity, content } = Astro.props;

const paragraphs = typeof entity.body === 'string' ? entity.body.split(/\n\s*\n/) : null;
const ptHtml = paragraphs === null && entity.body
  ? toHTML(entity.body as never, { components: { types: { image: () => '<!-- pt-image: unresolved until Task 14 -->' } } })
  : null;
---
<Base title={`${entity.name} — LINKAR`} description={entity.description}>
  <Navbar content={content} />

  <section class="hero" style={`background-image:linear-gradient(rgba(10,17,40,.82),rgba(10,17,40,.82)),url('${entity.heroImage}')`}>
    <div class="wrap">
      {entity.logo && (
        <span class="logo-chip"><img src={entity.logo} alt={`Logo ${entity.name}`} /></span>
      )}
      <h1 data-split>{entity.name}</h1>
      <p class="meta">{entity.role} · {entity.tagline}</p>
    </div>
  </section>

  {entity.description && (
    <section class="section lead">
      <div class="wrap prose">
        <p class="lead-text" data-reveal>{entity.description}</p>
      </div>
    </section>
  )}

  {(paragraphs !== null || ptHtml !== null) && (
    <section class="section body">
      <div class="wrap prose">
        {paragraphs !== null
          ? paragraphs.map((p) => <p>{p}</p>)
          : <div set:html={ptHtml} />}
      </div>
    </section>
  )}

  {entity.website && (
    <section class="section website">
      <div class="wrap">
        <a href={entity.website} target="_blank" rel="noopener" class="btn btn-ghost">Kunjungi Situs Web →</a>
      </div>
    </section>
  )}

  <section class="section cta">
    <div class="wrap">
      <h2>Kolaborasi dengan {entity.name}?</h2>
      <a href="/#contact" class="btn btn-primary">Ajak Kolaborasi →</a>
    </div>
  </section>

  <Footer content={content} />
</Base>

<style>
  .hero{background-size:cover;background-position:center;padding:120px 0 80px}
  .logo-chip{display:inline-flex;align-items:center;justify-content:center;background:#fff;border-radius:12px;padding:10px 18px;margin-bottom:24px}
  .logo-chip img{height:36px;width:auto;max-width:160px;object-fit:contain;display:block}
  .hero h1{font-size:clamp(2.2rem,6vw,3.6rem);max-width:820px}
  .hero .meta{color:var(--muted);font-weight:600;margin-top:16px}

  .lead{padding:64px 0 0}
  .lead-text{font-size:clamp(1.1rem,2.4vw,1.35rem);color:var(--text);max-width:780px}

  .body{padding:40px 0 72px}
  .prose{max-width:780px}
  .prose :global(p){margin-bottom:1.2em;color:var(--text)}

  .website{padding:0 0 72px}

  .cta{background:var(--navy-panel);text-align:center;padding:72px 0}
  .cta h2{font-size:clamp(1.8rem,4vw,2.6rem);margin-bottom:28px}
</style>
