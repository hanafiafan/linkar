---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import { getContent } from '../../lib/content';

const content = await getContent();
if (content.posts.length === 0) return Astro.redirect('/');
---
<Base title="Blog — LINKAR">
  <Navbar content={content} />
  <section class="section head">
    <div class="wrap">
      <span class="kicker">BLOG &amp; ARTIKEL</span>
      <h2>Tulisan &amp; Kabar</h2>
      <div class="grid" data-stagger>
        {content.posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
  <Footer content={content} />
</Base>

<style>
  .head{padding-top:64px}
  h2{font-size:clamp(2rem,5vw,3rem);margin-top:20px}
  .grid{display:grid;grid-template-columns:1fr;gap:24px;margin-top:40px}
  @media (min-width:700px){.grid{grid-template-columns:repeat(2,1fr)}}
  @media (min-width:1000px){.grid{grid-template-columns:repeat(3,1fr)}}
</style>
