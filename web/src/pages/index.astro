---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import EntityMarquee from '../components/EntityMarquee.astro';
import About from '../components/About.astro';
import PortfolioSection from '../components/PortfolioSection.astro';
import Services from '../components/Services.astro';
import StatsLinkar from '../components/StatsLinkar.astro';
import IndustryStats from '../components/IndustryStats.astro';
import Commitments from '../components/Commitments.astro';
import ContactCta from '../components/ContactCta.astro';
import Footer from '../components/Footer.astro';
import { getContent } from '../lib/content';

const content = await getContent();
const vis = content.home.visibility ?? {};
---
<Base title="LINKAR">
  <Navbar content={content} />
  {vis.hero !== false && <Hero content={content} />}
  {vis.marquee !== false && <EntityMarquee content={content} />}
  {vis.about !== false && <About content={content} />}
  {vis.portfolio !== false && <PortfolioSection content={content} />}
  {vis.services !== false && <Services content={content} />}
  {vis.linkarStats !== false && <StatsLinkar content={content} />}
  {vis.industry !== false && <IndustryStats content={content} />}
  {vis.commitments !== false && <Commitments content={content} />}
  {vis.cta !== false && <ContactCta content={content} />}
  <Footer content={content} />
</Base>
